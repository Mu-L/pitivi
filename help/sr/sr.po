#. (itstool) path: section/title
#: C/mainwindow.page:164
msgid "Middle pane"
msgstr "Средња површ"

#. (itstool) path: section/p
#: C/mainwindow.page:165
msgid ""
"The middle pane contains <gui>Clip configuration</gui>, <gui>Transitions</"
